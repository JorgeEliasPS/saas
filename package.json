{
  "name": "gena-api",
  "version": "1.0.0",
  "description": "Modern, stable and scalable WhatsApp Web API built with Fastify, Baileys and Redis",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs => fs.cpSync('src/public', 'dist/public', { recursive: true }))\"",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "tsx src/tests/test_api.js"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "fastify",
    "redis",
    "api"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.2.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.8",
    "audio-decode": "^2.2.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.4.1",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "qrcode": "^1.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.14.9",
    "@types/qrcode": "^1.5.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.5.2"
  }
}
