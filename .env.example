# GenaAPI Configuration Example

# Server configuration
PORT=3000
HOST=0.0.0.0
API_KEY=gena_api_secret_key_12345

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Log level (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info

# File Storage Configuration
# Temp uploads dir (for processing audio conversion)
UPLOADS_DIR=./uploads
# Session credentials directory (for caching / backup if necessary, though Redis is primary)
SESSIONS_DIR=./sessions
